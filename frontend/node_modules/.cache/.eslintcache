n      setValidate({\r\n        validate: validator.errors,\r\n      });\r\n\r\n      isValid = false;\r\n    }\r\n    return isValid;\r\n  };\r\n\r\n  const Navigate = useNavigate();\r\n  const register = (e) => {\r\n    e.preventDefault();\r\n    const data = {\r\n      fullname: fullname,\r\n      email: email,\r\n      password: password,\r\n\r\n      // other fields...\r\n    };\r\n\r\n    axios\r\n      .post(\"http://localhost:1313/regi\", data)\r\n      .then((res) => {\r\n        console.log(res.data);\r\n      })\r\n      .catch((error) => {\r\n        console.log(error);\r\n      });\r\n\r\n    const validate = validateRegister();\r\n\r\n    if (validate) {\r\n      setValidate({});\r\n      setName(\"\");\r\n      setEmail(\"\");\r\n      setPassword(\"\");\r\n      alert(\"Successfully Register User\");\r\n      Navigate(\"/\");\r\n    }\r\n  };\r\n\r\n  const togglePassword = (e) => {\r\n    if (showPassword) {\r\n      setShowPassword(false);\r\n    } else {\r\n      setShowPassword(true);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"row g-0 auth-wrapper\">\r\n      <div className=\"col-12 col-md-5 col-lg-6 h-100 auth-background-col\">\r\n        <div className=\"auth-background-holder\"></div>\r\n        <div className=\"auth-background-mask\"></div>\r\n      </div>\r\n\r\n      <div className=\"d-flex flex-column align-content-end\">\r\n        <div className=\"auth-body mx-auto\">\r\n          <div className=\"auth-form-container text-start\">\r\n            <form\r\n              className=\"auth-form\"\r\n              method=\"POST\"\r\n              onSubmit={register}\r\n              autoComplete={\"off\"}\r\n            >\r\n              <p>Register</p>\r\n\r\n              <div className=\"name mb-3\">\r\n                <input\r\n                  type=\"text\"\r\n                  className={`form-control ${\r\n                    validate.validate && validate.validate.name\r\n                      ? \"is-invalid \"\r\n                      : \"\"\r\n                  }`}\r\n                  id=\"name\"\r\n                  name=\"fullname\"\r\n                  value={fullname}\r\n                  placeholder=\"Name\"\r\n                  onChange={(e) => setName(e.target.value)}\r\n                />\r\n\r\n                <div\r\n                  className={`invalid-feedback text-start ${\r\n                    validate.validate && validate.validate.name\r\n                      ? \"d-block\"\r\n                      : \"d-none\"\r\n                  }`}\r\n                >\r\n                  {validate.validate && validate.validate.name\r\n                    ? validate.validate.name[0]\r\n                    : \"\"}\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"email mb-3\">\r\n                <input\r\n                  type=\"email\"\r\n                  className={`form-control ${\r\n                    validate.validate && validate.validate.email\r\n                      ? \"is-invalid \"\r\n                      : \"\"\r\n                  }`}\r\n                  id=\"email\"\r\n                  name=\"email\"\r\n                  value={email}\r\n                  placeholder=\"Email\"\r\n                  onChange={(e) => setEmail(e.target.value)}\r\n                />\r\n\r\n                <div\r\n                  className={`invalid-feedback text-start ${\r\n                    validate.validate && validate.validate.email\r\n                      ? \"d-block\"\r\n                      : \"d-none\"\r\n                  }`}\r\n                >\r\n                  {validate.validate && validate.validate.email\r\n                    ? validate.validate.email[0]\r\n                    : \"\"}\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"password mb-3\">\r\n                <div className=\"input-group\">\r\n                  <input\r\n                    type={showPassword ? \"text\" : \"password\"}\r\n                    className={`form-control ${\r\n                      validate.validate && validate.validate.password\r\n                        ? \"is-invalid \"\r\n                        : \"\"\r\n                    }`}\r\n                    name=\"password\"\r\n                    id=\"password\"\r\n                    value={password}\r\n                    placeholder=\"Password\"\r\n                    onChange={(e) => setPassword(e.target.value)}\r\n                  />\r\n\r\n                  <button\r\n                    type=\"button\"\r\n                    className=\"btn btn-outline-primary btn-sm\"\r\n                    onClick={(e) => togglePassword(e)}\r\n                  >\r\n                    <i\r\n                      className={\r\n                        showPassword ? \"far fa-eye\" : \"far fa-eye-slash\"\r\n                      }\r\n                    ></i>{\" \"}\r\n                  </button>\r\n\r\n                  <div\r\n                    className={`invalid-feedback text-start ${\r\n                      validate.validate && validate.validate.password\r\n                        ? \"d-block\"\r\n                        : \"d-none\"\r\n                    }`}\r\n                  >\r\n                    {validate.validate && validate.validate.password\r\n                      ? validate.validate.password[0]\r\n                      : \"\"}\r\n                  </div>\r\n                </div>\r\n              </div>\r\n              <div className=\"text-center\">\r\n                <button\r\n                  type=\"submit\"\r\n                  className=\"btn btn-primary w-100 theme-btn mx-auto\"\r\n                  onClick={register}\r\n                >\r\n                  Sign Up\r\n                </button>\r\n              </div>\r\n            </form>\r\n\r\n            <hr />\r\n            <div className=\"auth-option text-center pt-2\">\r\n              Have an account?{\" \"}\r\n              <Link className=\"text-link\" to=\"/\">\r\n                Sign in\r\n              </Link>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Register;\r\n","D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\pages\\Forgot.js",[],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\pages\\Login.js",["135","136","137","138","139","140"],"import { useState } from \"react\";\r\nimport { Link, useNavigate } from \"react-router-dom\";\r\nimport axios from \"axios\";\r\nimport { useGetAllProductsQuery } from \"../../slices/productsApi\";\r\nimport Form from \"../pages/Forms\";\r\nconst Login = () => {\r\n  const [email, setEmail] = useState(\"\");\r\n  const [password, setPassword] = useState(\"\");\r\n  const [remember, setRemember] = useState(false);\r\n  const [validate, setValidate] = useState({});\r\n  const [showPassword, setShowPassword] = useState(false);\r\n  const [errorMessages, setErrorMessages] = useState({});\r\n  const [isSubmitted, setIsSubmitted] = useState(false);\r\n\r\n  const renderErrorMessage = (name) =>\r\n    name === errorMessages.name && (\r\n      <div className=\"error\">{errorMessages.message}</div>\r\n    );\r\n\r\n  const data = {\r\n    email: email,\r\n    password: password,\r\n  };\r\n\r\n  const validateLogin = () => {\r\n    let isValid = true;\r\n    let validator = Form.validator({\r\n      email: {\r\n        value: email,\r\n        isRequired: true,\r\n        isEmail: true,\r\n      },\r\n      password: {\r\n        value: password,\r\n        isRequired: true,\r\n        minLength: 6,\r\n      },\r\n    });\r\n\r\n    if (validator !== null) {\r\n      setValidate({\r\n        validate: validator.errors,\r\n      });\r\n\r\n      isValid = false;\r\n    }\r\n    return isValid;\r\n  };\r\n\r\n  const Navigate = useNavigate();\r\n  const authenticate = async (e) => {\r\n    const validate = validateLogin();\r\n    e.preventDefault();\r\n    if (validate) {\r\n      setValidate({});\r\n      setEmail(\"\");\r\n      setPassword(\"\");\r\n      Navigate(\"/home\");\r\n    }\r\n\r\n    axios\r\n      .post(\"http://localhost:1313/login\", data)\r\n      .then((res) => {\r\n        console.log(JSON.stringify(res));\r\n        var res = res.data;\r\n        if (res.success == false) {\r\n          alert(res.message);\r\n          console.log(\"invalid\", res.message);\r\n        } else {\r\n          console.log(res.data);\r\n          //router and store the user data in session or local\r\n          sessionStorage.setItem(\"UserInfo\", res.data[0].fullname);\r\n          sessionStorage.setItem(\"UserInfo1\", res.data[0].email);\r\n          sessionStorage.setItem(\"UserInfoID\", res.data[0].id);\r\n          // var store = localStorage.getItem(\"UserInfo\");\r\n          // console.log(store);\r\n          // Navigate(\"/home\");\r\n        }\r\n\r\n        console.log(res.data);\r\n        return false;\r\n      })\r\n      .catch((error) => {\r\n        console.log(error);\r\n      });\r\n    return false;\r\n  };\r\n\r\n  const togglePassword = (e) => {\r\n    if (showPassword) {\r\n      setShowPassword(false);\r\n    } else {\r\n      setShowPassword(true);\r\n    }\r\n  };\r\n\r\n  return (\r\n    // <div className=\"col-12 col-md-7 col-lg-6 auth-main-col text-center\">\r\n    <div className=\"d-flex flex-column align-content-end\">\r\n      <div className=\"auth-body mx-auto\">\r\n        <div className=\"auth-form-container text-start\">\r\n          <form\r\n            className=\"auth-form\"\r\n            method=\"POST\"\r\n            // onSubmit={onSubmit}\r\n            autoComplete={\"off\"}\r\n          >\r\n            <h2>Login to your account</h2>\r\n\r\n            <div className=\"email mb-3\">\r\n              <input\r\n                type=\"email\"\r\n                className={`form-control ${\r\n                  validate.validate && validate.validate.email\r\n                    ? \"is-invalid \"\r\n                    : \"\"\r\n                }`}\r\n                id=\"email\"\r\n                name=\"email\"\r\n                value={email}\r\n                placeholder=\"Email\"\r\n                onChange={(e) => setEmail(e.target.value)}\r\n              />\r\n              {renderErrorMessage(\"email\")}\r\n\r\n              <div\r\n                className={`invalid-feedback text-start ${\r\n                  validate.validate && validate.validate.email\r\n                    ? \"d-block\"\r\n                    : \"d-none\"\r\n                }`}\r\n              >\r\n                {validate.validate && validate.validate.email\r\n                  ? validate.validate.email[0]\r\n                  : \"\"}\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"password mb-3\">\r\n              <div className=\"input-group\">\r\n                <input\r\n                  type={showPassword ? \"text\" : \"password\"}\r\n                  className={`form-control ${\r\n                    validate.validate && validate.validate.password\r\n                      ? \"is-invalid \"\r\n                      : \"\"\r\n                  }`}\r\n                  name=\"password\"\r\n                  id=\"password\"\r\n                  value={password}\r\n                  placeholder=\"Password\"\r\n                  onChange={(e) => setPassword(e.target.value)}\r\n                />\r\n                {renderErrorMessage(\"password\")}\r\n\r\n                <button\r\n                  type=\"button\"\r\n                  className=\"btn btn-outline-primary btn-sm\"\r\n                  onClick={(e) => togglePassword(e)}\r\n                >\r\n                  <i\r\n                    className={showPassword ? \"far fa-eye\" : \"far fa-eye-slash\"}\r\n                  ></i>{\" \"}\r\n                </button>\r\n\r\n                <div\r\n                  className={`invalid-feedback text-start ${\r\n                    validate.validate && validate.validate.password\r\n                      ? \"d-block\"\r\n                      : \"d-none\"\r\n                  }`}\r\n                >\r\n                  {validate.validate && validate.validate.password\r\n                    ? validate.validate.password[0]\r\n                    : \"\"}\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"extra mt-3 row justify-content-between\">\r\n                <div className=\"col-6\">\r\n                  <div className=\"form-check\">\r\n                    <input\r\n                      className=\"form-check-input\"\r\n                      type=\"checkbox\"\r\n                      id=\"remember\"\r\n                      checked={remember}\r\n                      onChange={(e) => setRemember(e.currentTarget.checked)}\r\n                    />\r\n                    <label className=\"form-check-label\" htmlFor=\"remember\">\r\n                      Remember me\r\n                    </label>\r\n                  </div>\r\n                </div>\r\n                <div className=\"col-6\">\r\n                  <div className=\"forgot-password text-end\">\r\n                    <Link to=\"/forgot\">Forgot password?</Link>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div className=\"text-center\">\r\n              <button\r\n                type=\"button\"\r\n                className=\"btn btn-primary w-100 theme-btn mx-auto\"\r\n                onClick={authenticate}\r\n              >\r\n                Log In\r\n              </button>\r\n            </div>\r\n          </form>\r\n\r\n          <hr />\r\n          <div className=\"auth-option text-center pt-2\">\r\n            No Account?{\" \"}\r\n            <Link className=\"text-link\" to=\"/regi\">\r\n              Sign up{\" \"}\r\n            </Link>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Login;\r\n","D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Menu.js\\TV\\Tv.js",["141","142","143","144","145","146"],"import React, { useEffect, useState } from \"react\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport CartSlice, { addToCart } from \"../../../slices/cartSlice\";\r\nimport { useNavigate } from \"react-router-dom\";\r\nimport { useGetAllLaptopQuery, useGetAllProductsQuery } from \"./TvApi\";\r\n\r\nconst Mobile = () => {\r\n  const { items: products, status } = useSelector((state) => state.products);\r\n  const dispatch = useDispatch();\r\n  const history = useNavigate();\r\n\r\n  const { data, error, isLoading } = useGetAllProductsQuery();\r\n\r\n  console.log(\"mera data\", data);\r\n  console.log(\"Api\", isLoading);\r\n\r\n  const handleAddToCart = (product) => {\r\n    dispatch(addToCart(product));\r\n    history(\"/cart\");\r\n  };\r\n\r\n  return (\r\n    <>\r\n      <div className=\"home-container\">\r\n        {status === \"success\" ? (\r\n          <>\r\n            <h2>New Arrivals</h2>\r\n            <div className=\"\">\r\n              {data &&\r\n                data?.map((item) => (\r\n                  <div className=\"cart-items\" key={item.id}>\r\n                    <h3 className=\"\">{item.cat_name}</h3>\r\n\r\n                    {item?.products.map((product, index) => (\r\n                      <div className=\"product\">\r\n                        <h3>{product.name}</h3>\r\n                        <img\r\n                          src={\"http://localhost:1313/images/\" + product.image}\r\n                          alt={product.name}\r\n                        />\r\n                        <div className=\"details\">\r\n                          <span className=\"\">{product.desc}</span>\r\n                          <span className=\"price\">${product.price}</span>\r\n          