            <h3 className=\"\">{item.cat_name}</h3>\r\n\r\n                    {item?.products.map((product, index) => (\r\n                      <div className=\"product\">\r\n                        <h3>{product.name}</h3>\r\n                        <img\r\n                          src={\"http://localhost:1313/images/\" + product.image}\r\n                          alt={product.name}\r\n                        />\r\n                        <div className=\"details\">\r\n                          <span className=\"\">{product.desc}</span>\r\n                          <span className=\"price\">${product.price}</span>\r\n                        </div>\r\n                        <button onClick={() => handleAddToCart(product)}>\r\n                          Add To Cart\r\n                        </button>\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                ))}\r\n            </div>\r\n          </>\r\n        ) : status === \"pending\" ? (\r\n          <p>Loading...</p>\r\n        ) : (\r\n          <p>Unexpected error occured...</p>\r\n        )}\r\n\r\n        {/* <div><Cart /></div> */}\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Laptop;\r\n","D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\NavBar.jsx",["170","171"],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Cart.jsx",["172","173"],"import { useEffect, useState } from \"react\";\nimport { useDispatch, useSelector } from \"react-redux\";\nimport {\n  addToCart,\n  clearCart,\n  decreaseCart,\n  getTotals,\n  removeFromCart,\n} from \"../slices/cartSlice\";\nimport StripeCheckout from \"react-stripe-checkout\";\nimport { Link } from \"react-router-dom\";\nimport CheckOut from \"./Checkout/CheckOut\";\nimport axios from \"axios\";\nimport { toast } from \"react-toastify\";\n\nimport \"react-toastify/dist/ReactToastify.css\";\nconst Cart = () => {\n  var email = sessionStorage.getItem(\"UserInfo1\");\n  console.log(email);\n  var name = sessionStorage.getItem(\"UserInfo\");\n  console.log(name);\n  var userid = sessionStorage.getItem(\"UserInfoID\");\n  console.log(userid);\n\n  toast.configure();\n  const cart = useSelector((state) => state.cart);\n  const dispatch = useDispatch();\n\n  useEffect(() => {\n    dispatch(getTotals());\n  }, [cart, dispatch]);\n\n  const handleAddToCart = (product) => {\n    dispatch(addToCart(product));\n  };\n  const handleDecreaseCart = (product) => {\n    dispatch(decreaseCart(product));\n  };\n  const handleRemoveFromCart = (product) => {\n    dispatch(removeFromCart(product));\n  };\n  const handleClearCart = () => {\n    dispatch(clearCart());\n  };\n  //product object name,price\n  //   async function handleToken(token,address){\n  //     const res = await axios.post(\"http://localhost:1313/checkout\",{token,cart})\n  //     //take res\n  //     console.log(res.status)\n\n  //     if(res.status === 200){\n  // toast(\"payment Success\",{type:\"success\"})\n  //     }else{\n  // toast(\"Failure payment is not completed\",{type:\"error\"})\n  //     }\n  //   }\n  const handleToken = async (token) => {\n    console.log(\"handle token\");\n    axios\n      .post(\"http://localhost:1313/checkout\", {\n        token,\n        cart,\n        userid,\n      })\n      .then((res) => {\n        console.log(res.data);\n        toast(\"payment Success\", { type: \"success\" });\n        // localStorage.removeItem(\"cartItems\");\n      })\n      .catch((err) => {\n        toast(\"Failure payment is not completed\", { type: \"error\" });\n        console.log(err);\n      });\n  };\n\n  return (\n    <div className=\"cart-container\">\n      <h2>Shopping Cart</h2>\n      {cart.cartItems.length === 0 ? (\n        <div className=\"cart-empty\">\n          <p>Your cart is currently empty</p>\n          <div className=\"start-shopping\">\n            <Link to=\"/home\">\n              <svg\n                xmlns=\"http://www.w3.org/2000/svg\"\n                width=\"20\"\n                height=\"20\"\n                fill=\"currentColor\"\n                className=\"bi bi-arrow-left\"\n                viewBox=\"0 0 16 16\"\n              >\n                <path\n                  fillRule=\"evenodd\"\n                  d=\"M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z\"\n                />\n              </svg>\n              <span>Start Shopping</span>\n            </Link>\n          </div>\n        </div>\n      ) : (\n        <div>\n          <div className=\"titles\">\n            <h3 className=\"product-title\">Product</h3>\n            <h3 className=\"price\">Price</h3>\n            <h3 className=\"quantity\">Quantity</h3>\n            <h3 className=\"total\">Total</h3>\n          </div>\n          <div className=\"cart-items\">\n            {cart.cartItems &&\n              cart.cartItems.map((cartItem) => (\n                <div className=\"cart-item\" key={cartItem.id}>\n                  <div className=\"cart-product\">\n                    <img\n                      src={\"http://localhost:1313/images/\" + cartItem.image}\n                      alt={cartItem.name}\n                    />\n                    <div>\n                      <h3>{cartItem.name}</h3>\n                      <p>{cartItem.pro_desc}</p>\n                      <button onClick={() => handleRemoveFromCart(cartItem)}>\n                        Remove\n                      </button>\n                    </div>\n                  </div>\n                  <div className=\"cart-product-price\">₹{cartItem.price}</div>\n                  <div className=\"cart-product-quantity\">\n                    <button onClick={() => handleDecreaseCart(cartItem)}>\n                      -\n                    </button>\n                    <div className=\"count\">{cartItem.cartQuantity}</div>\n                    <button onClick={() => handleAddToCart(cartItem)}>+</button>\n                  </div>\n                  <div className=\"cart-product-total-price\">\n                    ₹{cartItem.price * cartItem.cartQuantity}\n                  </div>\n                </div>\n              ))}\n          </div>\n          <div className=\"cart-summary\">\n            <button className=\"clear-btn\" onClick={() => handleClearCart()}>\n              Clear Cart\n            </button>\n            <div className=\"cart-checkout\">\n              <div className=\"subtotal\">\n                <span>Subtotal</span>\n                <span className=\"amount\">₹{cart.cartTotalAmount}</span>\n              </div>\n              <p>Taxes and shipping calculated at checkout</p>\n\n              <button>\n                <StripeCheckout\n                  className=\"flex w-full\"\n                  stripeKey=\"pk_test_uNtUbsKyB6tXqfxx2l78iuPu00Upvk5XUJ\"\n                  token={handleToken}\n                  amount={cart.cartTotalAmount * 100}\n                  name={name}\n                  email={email}\n                  currency=\"INR\"\n\n                  // billingAddress\n                  // shippingAddress\n                />\n              </button>\n              <div className=\"continue-shopping\">\n                <Link to=\"/home\">\n                  <svg\n                    xmlns=\"http://www.w3.org/2000/svg\"\n                    width=\"20\"\n                    height=\"20\"\n                    fill=\"currentColor\"\n                    className=\"bi bi-arrow-left\"\n                    viewBox=\"0 0 16 16\"\n                  >\n                    <path\n                      fillRule=\"evenodd\"\n                      d=\"M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z\"\n                    />\n                  </svg>\n                  <span>Continue Shopping</span>\n                </Link>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n};\n\nexport default Cart;\n","D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Home.jsx",["174","175","176","177","178"],"import { useEffect, useState } from \"react\";\nimport { useDispatch, useSelector } from \"react-redux\";\nimport { useHistory, useNavigate } from \"react-router-dom\";\nimport CartSlice, { addToCart } from \"../slices/cartSlice\";\nimport { useGetAllProductsQuery } from \"../slices/productsApi\";\nimport Banner from \"./pages/Banner\";\n// import Cart from \"./Cart\";\n\nconst Home = () => {\n  const { items: products, status } = useSelector((state) => state.products);\n  const dispatch = useDispatch();\n  const history = useNavigate();\n\n  const { data, isLoading } = useGetAllProductsQuery();\n\n  console.log(\"mera data\", data);\n  console.log(\"Api\", isLoading);\n\n  const handleAddToCart = (product) => {\n    dispatch(addToCart(product));\n    history(\"/cart\");\n  };\n\n  return (\n    <>\n      <Banner />\n      <div className=\"home-container\">\n        {status === \"success\" ? (\n          <>\n            <div className=\"products\">\n              {data &&\n                data?.map((item) => (\n                  <div className=\"cart-item\" key={item.id}>\n                    <h1 className=\"\">{item.cat_name}</h1>\n\n                    {item?.products.map((product, index) => (\n                      <div className=\"product\">\n                        <h3>{product.name}</h3>\n\n                        <img\n                          src={\"http://localhost:1313/images/\" + product.image}\n                          alt={product.name}\n                        />\n                        <div className=\"details\">\n                          <span className=\"\">{product.desc}</span>\n                          <span className=\"price\">₹{product.price}</span>\n                        </div>\n                        <button onClick={() => handleAddToCart(product)}>\n                          Add To Cart\n                        </button>\n                      </div>\n                    ))}\n                  </div>\n                ))}\n            </div>\n          </>\n        ) : status === \"pending\" ? (\n          <p>Loading...</p>\n        ) : (\n          <p>Unexpected error occured...</p>\n        )}\n\n        {/* <div><Cart /></div> */}\n      </div>\n    </>\n  );\n};\n\nexport default Home;\n","D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\NotFound.jsx",[],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\pages\\Forms.js",[],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Menu.js\\TV\\TvApi.js",[],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Menu.js\\laptop\\LaptopApi.js",[],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Menu.js\\AC\\AcApi.js",[],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Menu.js\\Watch\\WatchApi.js",[],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Menu.js\\Mobile\\MobileApi.js",[],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\slices\\api.js",[],["179","180"],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Checkout\\CheckOut.js",[],"D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Order\\MyOrder.js",["181","182","183","184","185"],"import axios from \"axios\";\r\nimport React, { useEffect, useState } from \"react\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport { useNavigate } from \"react-router-dom\";\r\nimport { useGetAllProductsQuery } from \"./MyorderApi\";\r\n\r\nconst MyOrder = () => {\r\n  const [renderData, setRenderData] = useState([]);\r\n  var userid = sessionStorage.getItem(\"UserInfoID\");\r\n  console.log(renderData);\r\n  useEffect(() => {\r\n    getAllData();\r\n  });\r\n\r\n  useEffect(() => {\r\n    const fetchData = async () => {\r\n      await fetch(`http://localhost:1313/myorder/${userid}`)\r\n        .then(async (res) => {\r\n          const data = await res.json();\r\n          console.log(data);\r\n          setRenderData(data);\r\n        })\r\n        .catch((err) => {\r\n          console.log(\"err\", err);\r\n        });\r\n    };\r\n    fetchData();\r\n  }, []);\r\n\r\n  const getAllData = () => {\r\n    axios\r\n      .get(`http://localhost:1313/myorder/${userid}`)\r\n      .then((res_new) => {\r\n        //  const allData = res.data.orderData.allData;\r\n\r\n        console.log(res_new?.data);\r\n        //  setorderData(allData)\r\n      })\r\n      .catch((error) => {\r\n        console.log(\"Error\", error);\r\n      });\r\n  };\r\n\r\n  return (\r\n    <>\r\n      <table className=\"table\">\r\n        <thead>\r\n          <tr>\r\n            <th>order ID</th>\r\n            <th>Total</th>\r\n            <th>subTotal</th>\r\n            <th>Transication id</th>\r\n          </tr>\r\n        </thead>\r\n        <tbody>\r\n          {renderData?.map((data, index) => {\r\n            return (\r\n              <tr key={index}>\r\n                <td>#ONS00{data.id}</td>\r\n                <td>{data.total}</td>\r\n                <td>{data.subtotal}</td>\r\n                <td>{data.txn_id}</td>\r\n              </tr>\r\n            );\r\n          })}\r\n        </tbody>\r\n      </table>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default MyOrder;\r\n","D:\\complete-shopping-cart-main\\shopping-card\\frontend\\src\\components\\Order\\MyorderApi.js",[],{"ruleId":"186","replacedBy":"187"},{"ruleId":"188","replacedBy":"189"},{"ruleId":"190","severity":1,"message":"191","line":10,"column":11,"nodeType":"192","endLine":14,"endColumn":13},{"ruleId":"190","severity":1,"message":"191","line":21,"column":11,"nodeType":"192","endLine":25,"endColumn":13},{"ruleI